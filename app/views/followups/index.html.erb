<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Followups</h1>
  <div class="flex gap-2 text-sm">
    <%= link_to "All", followups_path, class: "px-3 py-1 rounded-md #{params[:status].blank? ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100'}" %>
    <%= link_to "Pending", followups_path(status: :pending), class: "px-3 py-1 rounded-md #{params[:status] == 'pending' ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100'}" %>
    <%= link_to "Completed", followups_path(status: :completed), class: "px-3 py-1 rounded-md #{params[:status] == 'completed' ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100'}" %>
    <%= link_to "Skipped", followups_path(status: :skipped), class: "px-3 py-1 rounded-md #{params[:status] == 'skipped' ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100'}" %>
  </div>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Contact</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Company</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Seq #</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Scheduled</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @followups.each do |followup| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm">
            <%= link_to followup.contact.name || followup.contact.email, followup.contact, class: "text-blue-600 hover:text-blue-800" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= followup.contact.company.name %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= followup.sequence_number %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= followup.scheduled_at&.strftime("%b %d, %Y") || "—" %></td>
          <td class="px-6 py-4"><%= render "shared/status_badge", status: followup.status %></td>
          <td class="px-6 py-4 text-right">
            <% if followup.pending? %>
              <%= button_to "Skip", skip_followup_path(followup), method: :post, class: "text-sm text-red-600 hover:text-red-800" %>
            <% end %>
            <% if followup.draft.present? %>
              <%= link_to "View Draft", followup.draft, class: "text-sm text-blue-600 hover:text-blue-800 ml-2" %>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @followups.empty? %>
        <tr>
          <td colspan="6" class="px-6 py-8 text-center text-gray-500">No followups.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
