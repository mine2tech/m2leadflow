<div class="max-w-2xl mx-auto relative">
  <% if timeline.empty? %>
    <div class="empty-state py-24">
      <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      <p class="empty-state-title">No conversation yet</p>
      <p class="empty-state-description">Generate an AI draft to get started</p>
    </div>
  <% else %>
    <%# Vertical timeline connector %>
    <div class="absolute left-4 top-6 bottom-6 w-px bg-slate-200"></div>

    <% prev_at = nil %>
    <% last_outbound = nil %>

    <% timeline.each do |item| %>
      <%# Date separator if > 3 days gap %>
      <% if prev_at && (item[:at] - prev_at) > 3.days %>
        <div class="flex items-center gap-3 my-6 relative z-10">
          <div class="flex-1 border-t border-slate-200"></div>
          <span class="text-xs font-medium text-slate-400 bg-slate-50 px-2"><%= item[:at].strftime("%b %-d, %Y") %></span>
          <div class="flex-1 border-t border-slate-200"></div>
        </div>
      <% end %>

      <% if item[:type] == :draft %>
        <div class="relative pl-10 mb-4">
          <div class="absolute left-2.5 top-4 w-3 h-3 rounded-full bg-indigo-400 border-2 border-white z-10"></div>
          <%= render 'contacts/timeline_draft_item', draft: item[:record] %>
        </div>
      <% elsif item[:type] == :message %>
        <% msg = item[:record] %>
        <% if msg.inbound? && last_outbound %>
          <%= render 'contacts/awaiting_reply', sent_at: last_outbound.created_at %>
          <% last_outbound = nil %>
        <% end %>
        <div class="relative pl-10 mb-4">
          <div class="absolute left-2.5 top-4 w-3 h-3 rounded-full <%= msg.inbound? ? 'bg-emerald-400' : 'bg-indigo-400' %> border-2 border-white z-10"></div>
          <%= render 'contacts/timeline_message_item', message: msg, contact: contact %>
        </div>
        <% last_outbound = msg if msg.outbound? %>
      <% end %>

      <% prev_at = item[:at] %>
    <% end %>

    <%# Show "awaiting reply" after last outbound if no reply yet %>
    <% if last_outbound && !contact.has_reply? %>
      <%= render 'contacts/awaiting_reply', sent_at: last_outbound.created_at %>
    <% end %>
  <% end %>
</div>
