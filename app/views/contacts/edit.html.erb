<%= render "shared/page_header",
  breadcrumbs: [["Companies", companies_path], [@contact.company.name, company_path(@contact.company)], [@contact.name || @contact.email, contact_path(@contact)], ["Edit", nil]],
  title: "Edit Contact" %>

<div class="card max-w-2xl">
  <div class="card-header">
    <h2 class="text-sm font-semibold text-slate-900">Edit <%= @contact.name || @contact.email %></h2>
    <p class="text-xs text-slate-500 mt-0.5"><%= @contact.company.name %></p>
  </div>
  <div class="card-body">
    <%= form_with(model: @contact, class: "space-y-4") do |f| %>
      <% if @contact.errors.any? %>
        <div class="bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-lg text-sm">
          <ul class="list-disc list-inside">
            <% @contact.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label class="form-label">Name</label>
        <%= f.text_field :name, class: "form-input" %>
      </div>

      <div>
        <label class="form-label">Email</label>
        <%= f.email_field :email, class: "form-input", required: true %>
      </div>

      <div>
        <label class="form-label">Role</label>
        <%= f.text_field :role, class: "form-input", placeholder: "e.g. CTO, VP Sales" %>
        <p class="text-xs text-slate-400 mt-1">The contact's job title or role at the company.</p>
      </div>

      <div class="flex gap-3 pt-2 border-t border-slate-100">
        <%= f.submit "Update Contact", class: "btn-primary cursor-pointer" %>
        <%= link_to "Cancel", @contact, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
