<div class="rounded-xl border p-4 <%= message.outbound? ? 'bg-slate-50 border-slate-200' : 'bg-white border-slate-200 ring-1 ring-emerald-100' %>">
  <div class="flex items-center justify-between mb-2">
    <p class="text-xs font-semibold <%= message.outbound? ? 'text-slate-500' : 'text-emerald-600' %>">
      <% if message.outbound? %>
        You
      <% else %>
        <%= contact.name || "Them" %>
      <% end %>
    </p>
    <span class="text-xs text-slate-400"><%= message.created_at.strftime("%b %-d, %l:%M %p") %></span>
  </div>
  <% if message.subject.present? %>
    <p class="text-sm font-medium text-slate-800 mb-2"><%= message.subject %></p>
  <% end %>
  <p class="text-sm text-slate-700 whitespace-pre-wrap"><%= message.body %></p>
</div>
