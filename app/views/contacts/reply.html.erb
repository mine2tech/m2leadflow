<%= render "shared/page_header",
  breadcrumbs: [["Companies", companies_path], [@contact.company.name, company_path(@contact.company)], [@contact.name || @contact.email, contact_path(@contact)], ["Reply", nil]],
  title: "Reply to Thread" %>

<div class="max-w-4xl mx-auto">
  <%# Previous messages in thread %>
  <div class="card mb-6">
    <div class="card-header">
      <h3 class="text-sm font-semibold text-slate-900">Conversation</h3>
    </div>
    <div class="card-body space-y-4 max-h-96 overflow-y-auto">
      <% @messages.each do |message| %>
        <div class="<%= message.inbound? ? 'pl-0' : 'pl-4 border-l-2 border-indigo-200' %>">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-medium <%= message.inbound? ? 'text-emerald-600' : 'text-indigo-600' %>">
              <%= message.inbound? ? (@contact.name || @contact.email) : "You" %>
            </span>
            <span class="text-xs text-slate-400"><%= message.created_at.strftime("%b %-d, %l:%M %p") %></span>
          </div>
          <p class="text-sm text-slate-700 whitespace-pre-wrap"><%= message.body.truncate(500) %></p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Reply compose form %>
  <div class="card">
    <div class="card-header">
      <h3 class="text-sm font-semibold text-slate-900">Your Reply</h3>
    </div>
    <div class="card-body">
      <%= form_with(model: @draft, url: drafts_path, class: "space-y-4") do |f| %>
        <%= f.hidden_field :contact_id %>
        <%= f.hidden_field :email_thread_id %>

        <div>
          <label class="form-label">Subject</label>
          <%= f.text_field :subject, class: "form-input w-full" %>
        </div>

        <div>
          <label class="form-label">Body</label>
          <%= f.text_area :body, class: "form-input font-mono w-full", rows: 8, required: true, autofocus: true %>
        </div>

        <div>
          <label class="form-label">Attachments</label>
          <%= f.file_field :attachments, multiple: true, class: "form-input text-sm w-full file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
        </div>

        <div class="flex gap-3 pt-4 border-t border-slate-100">
          <%= f.submit "Save Reply as Draft", class: "btn-primary cursor-pointer" %>
          <%= link_to "Cancel", contact_path(@contact), class: "btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
