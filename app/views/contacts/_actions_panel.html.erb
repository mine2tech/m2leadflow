<%# Contact identity %>
<div class="mb-5">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-xl font-semibold text-gray-900"><%= contact.name || contact.email %></h1>
      <% if contact.role.present? %>
        <p class="text-xs text-gray-500 mt-0.5"><%= contact.role %></p>
      <% end %>
      <p class="text-xs text-gray-400 mt-0.5">
        <%= link_to contact.company.name, contact.company, class: "text-blue-600 hover:text-blue-800" %>
      </p>
    </div>
    <% stage = contact.pipeline_stage %>
    <% stage_colors = {
      pending: "bg-gray-100 text-gray-600",
      drafted: "bg-amber-100 text-amber-700",
      sent:    "bg-blue-100 text-blue-700",
      replied: "bg-emerald-100 text-emerald-700",
      meeting: "bg-violet-100 text-violet-700"
    } %>
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= stage_colors[stage] %>">
      <%= stage.to_s.capitalize %>
    </span>
  </div>
  <p class="text-xs text-gray-400 mt-2"><%= contact.email %></p>
</div>

<hr class="border-gray-100 mb-5">

<%# Primary action %>
<% pending_draft = drafts.find { |d| d.draft? || d.approved? } %>
<% if pending_draft %>
  <% if pending_draft.draft? %>
    <%= button_to "Approve Draft", approve_draft_path(pending_draft), method: :post,
      class: "w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2.5 px-4 rounded-md mb-2",
      data: { turbo_frame: dom_id(pending_draft) } %>
  <% elsif pending_draft.approved? %>
    <%= button_to "Send Email", send_email_draft_path(pending_draft), method: :post,
      class: "w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2.5 px-4 rounded-md mb-2",
      data: { turbo_confirm: "Send this email to #{contact.email}?", turbo_frame: dom_id(pending_draft) } %>
  <% end %>
<% end %>

<% if contact.last_outbound_at && !contact.has_reply? %>
  <button class="w-full border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium py-2.5 px-4 rounded-md mb-2">
    Write Followup
  </button>
<% end %>

<%= link_to "Log Meeting", new_meeting_path(contact_id: contact.id), class: "block text-center text-blue-600 text-sm font-medium py-1.5 mb-5 hover:text-blue-800" %>

<%# Followups %>
<% if followups.any? %>
  <div class="mb-5">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Followups</p>
    <% followups.each do |fu| %>
      <div class="flex items-center justify-between py-1.5">
        <span class="text-sm text-gray-700">Seq #<%= fu.sequence_number %></span>
        <span class="text-xs text-gray-400 flex items-center gap-2">
          <%= render "shared/status_badge", status: fu.status %>
          <% if fu.pending? %>
            <%= button_to "Skip", skip_followup_path(fu), method: :post, class: "text-xs text-red-500 hover:text-red-700 bg-transparent border-0 p-0 cursor-pointer" %>
          <% end %>
        </span>
      </div>
    <% end %>
  </div>
<% end %>

<%# Meetings %>
<% if meetings.any? %>
  <div class="mb-5">
    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Meetings</p>
    <% meetings.each do |meeting| %>
      <div class="flex items-center justify-between py-1.5">
        <span class="text-sm text-gray-700"><%= meeting.scheduled_at&.strftime("%b %-d, %l:%M %p") || "—" %></span>
        <%= render "shared/status_badge", status: meeting.status %>
      </div>
    <% end %>
  </div>
<% end %>

<hr class="border-gray-100 mb-4">

<%= link_to "Edit Contact", edit_contact_path(contact), class: "text-xs text-gray-400 hover:text-gray-600" %>
