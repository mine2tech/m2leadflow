<h1 class="text-2xl font-bold text-gray-900 mb-6">Add Contact to <%= @company.name %></h1>

<div class="bg-white rounded-lg border border-gray-200 p-6 max-w-lg">
  <%= form_with(model: [@company, @contact], class: "space-y-4") do |f| %>
    <% if @contact.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded text-sm">
        <ul class="list-disc list-inside">
          <% @contact.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border", required: true %>
    </div>

    <div>
      <%= f.label :role, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :role, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border", placeholder: "e.g. CTO, VP Sales" %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Create Contact", class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancel", @company, class: "px-4 py-2 rounded-md text-sm text-gray-600 hover:text-gray-900 border border-gray-300" %>
    </div>
  <% end %>
</div>
