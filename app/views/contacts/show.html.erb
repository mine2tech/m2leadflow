<%# Mobile: stacked layout. Desktop: 3-column panels %>
<div class="lg:grid lg:gap-0 lg:-mx-8 lg:-my-6 overflow-hidden" style="grid-template-columns: 340px 1fr 320px; min-height: calc(100vh - 0px);">
  <%# Left panel — actions + context %>
  <div class="border-b lg:border-b-0 lg:border-r border-slate-200 bg-white lg:overflow-y-auto lg:h-screen lg:sticky lg:top-0 px-5 py-5 sm:px-6 sm:py-6">
    <%= render 'contacts/actions_panel', contact: @contact, drafts: @drafts, followups: @followups, meetings: @meetings %>
  </div>

  <%# Center panel — conversation thread %>
  <div class="lg:overflow-y-auto lg:h-screen lg:sticky lg:top-0 bg-slate-50 px-4 py-5 sm:px-6 sm:py-6">
    <%= render 'contacts/conversation_timeline', timeline: @timeline, contact: @contact %>
  </div>

  <%# Right panel — activity & comments %>
  <div class="border-t lg:border-t-0 lg:border-l border-slate-200 bg-white lg:overflow-y-auto lg:h-screen lg:sticky lg:top-0">
    <%= render 'shared/activity_panel', activities: @activities, commentable: @contact %>
  </div>
</div>
