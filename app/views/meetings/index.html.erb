<% content_for(:actions) do %>
  <%= link_to new_meeting_path, class: "btn-primary" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Schedule Meeting
  <% end %>
<% end %>
<%= render "shared/page_header",
  title: "Meetings",
  breadcrumbs: [["Meetings", nil]],
  actions: content_for(:actions) %>

<%# Upcoming Meetings %>
<% if @upcoming_meetings.any? %>
  <h2 class="text-sm font-semibold text-slate-900 mb-3">Upcoming</h2>
  <div class="grid gap-3 mb-8">
    <% @upcoming_meetings.each do |meeting| %>
      <div class="card-interactive flex items-center gap-4 p-4 border-l-4 border-l-indigo-500">
        <div class="text-center flex-shrink-0 w-14">
          <p class="text-lg font-bold text-slate-900"><%= meeting.scheduled_at.strftime("%-d") %></p>
          <p class="text-xs text-slate-500 uppercase"><%= meeting.scheduled_at.strftime("%b") %></p>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2">
            <p class="text-sm font-medium text-slate-900">
              <%= link_to meeting.contact.name || meeting.contact.email, meeting.contact, class: "hover:text-indigo-600 transition-colors" %>
            </p>
            <span class="text-xs text-slate-400">&middot;</span>
            <span class="text-xs text-slate-500"><%= meeting.contact.company.name %></span>
          </div>
          <p class="text-xs text-slate-500 mt-0.5"><%= meeting.scheduled_at.strftime("%l:%M %p") %></p>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <% if meeting.meeting_link.present? %>
            <a href="<%= meeting.meeting_link %>" target="_blank" rel="noopener" class="btn-primary btn-sm">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              Join
            </a>
          <% end %>
          <%= link_to "Edit", edit_meeting_path(meeting), class: "btn-ghost btn-sm" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card mb-8">
    <%= render "shared/empty_state",
      title: "No upcoming meetings",
      description: "Schedule a meeting to track your conversations.",
      cta_text: "Schedule Meeting",
      cta_path: new_meeting_path,
      icon: '<svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>' %>
  </div>
<% end %>

<%# Past Meetings %>
<% if @past_meetings.any? %>
  <h2 class="text-sm font-semibold text-slate-900 mb-3">Past</h2>
  <div class="card overflow-hidden overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th scope="col">Contact</th>
          <th scope="col">Company</th>
          <th scope="col">Date</th>
          <th scope="col">Status</th>
          <th scope="col"></th>
        </tr>
      </thead>
      <tbody>
        <% @past_meetings.each do |meeting| %>
          <tr>
            <td class="text-sm">
              <%= link_to meeting.contact.name || meeting.contact.email, meeting.contact, class: "text-indigo-600 hover:text-indigo-700 transition-colors" %>
            </td>
            <td class="text-sm text-slate-600"><%= meeting.contact.company.name %></td>
            <td class="text-sm text-slate-600"><%= meeting.scheduled_at.strftime("%b %d, %Y") %></td>
            <td><%= render "shared/status_badge", status: meeting.status %></td>
            <td class="text-right">
              <div class="flex items-center gap-2 justify-end">
                <%= link_to "Edit", edit_meeting_path(meeting), class: "text-sm text-slate-400 hover:text-slate-700 transition-colors" %>
                <%= button_to "Delete", meeting, method: :delete, class: "text-sm text-rose-500 hover:text-rose-700 transition-colors", data: { turbo_confirm: "Delete this meeting?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
