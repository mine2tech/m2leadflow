<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Meetings</h1>
  <%= link_to "Schedule Meeting", new_meeting_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Contact</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Company</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date/Time</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Link</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @meetings.each do |meeting| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 text-sm">
            <%= link_to meeting.contact.name || meeting.contact.email, meeting.contact, class: "text-blue-600 hover:text-blue-800" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= meeting.contact.company.name %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= meeting.scheduled_at.strftime("%b %d, %Y %H:%M") %></td>
          <td class="px-6 py-4 text-sm">
            <% if meeting.meeting_link.present? %>
              <a href="<%= meeting.meeting_link %>" target="_blank" class="text-blue-600 hover:text-blue-800">Join</a>
            <% else %>
              <span class="text-gray-400">—</span>
            <% end %>
          </td>
          <td class="px-6 py-4"><%= render "shared/status_badge", status: meeting.status %></td>
          <td class="px-6 py-4 text-right flex gap-2 justify-end">
            <%= link_to "Edit", edit_meeting_path(meeting), class: "text-sm text-gray-600 hover:text-gray-900" %>
            <%= button_to "Delete", meeting, method: :delete, class: "text-sm text-red-600 hover:text-red-800", data: { turbo_confirm: "Delete this meeting?" } %>
          </td>
        </tr>
      <% end %>
      <% if @meetings.empty? %>
        <tr>
          <td colspan="6" class="px-6 py-8 text-center text-gray-500">No meetings scheduled.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
