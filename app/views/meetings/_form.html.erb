<%= form_with(model: meeting, class: "space-y-4") do |f| %>
  <% if meeting.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded text-sm">
      <ul class="list-disc list-inside">
        <% meeting.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :contact_id, "Contact", class: "block text-sm font-medium text-gray-700" %>
    <%= f.collection_select :contact_id, @contacts, :id, ->(c) { "#{c.name || c.email} (#{c.company.name})" }, { prompt: "Select contact" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
  </div>

  <div>
    <%= f.label :scheduled_at, "Date & Time", class: "block text-sm font-medium text-gray-700" %>
    <%= f.datetime_local_field :scheduled_at, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
  </div>

  <div>
    <%= f.label :meeting_link, "Meeting Link", class: "block text-sm font-medium text-gray-700" %>
    <%= f.url_field :meeting_link, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border", placeholder: "https://meet.google.com/..." %>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :notes, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border", rows: 3 %>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :status, Meeting.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Cancel", meetings_path, class: "px-4 py-2 rounded-md text-sm text-gray-600 hover:text-gray-900 border border-gray-300" %>
  </div>
<% end %>
