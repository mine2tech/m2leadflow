<%= render "shared/page_header",
  breadcrumbs: [["Meetings", meetings_path], ["Schedule Meeting", nil]],
  title: "Schedule Meeting" %>

<div class="card max-w-2xl">
  <div class="card-header">
    <h2 class="text-sm font-semibold text-slate-900">New Meeting</h2>
    <p class="text-xs text-slate-500 mt-0.5">Schedule a meeting with a contact in your pipeline.</p>
  </div>
  <div class="card-body">
    <%= render "form", meeting: @meeting %>
  </div>
</div>
