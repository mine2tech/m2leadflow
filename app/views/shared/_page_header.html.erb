<%# Locals: breadcrumbs (array of [label, path] pairs), title, subtitle (optional), actions (block) %>
<div class="mb-6">
  <% if local_assigns[:breadcrumbs]&.any? %>
    <nav class="flex items-center gap-1.5 text-sm mb-3 overflow-x-auto">
      <% breadcrumbs.each_with_index do |(label, path), i| %>
        <% if i > 0 %>
          <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
        <% if path %>
          <%= link_to label, path, class: "text-slate-500 hover:text-slate-700 transition-colors whitespace-nowrap" %>
        <% else %>
          <span class="text-slate-900 font-medium whitespace-nowrap"><%= label %></span>
        <% end %>
      <% end %>
    </nav>
  <% end %>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-slate-900 tracking-tight"><%= title %></h1>
      <% if local_assigns[:subtitle] %>
        <p class="text-sm text-slate-500 mt-1"><%= subtitle %></p>
      <% end %>
    </div>
    <% if local_assigns[:actions] %>
      <div class="flex items-center gap-2 flex-shrink-0">
        <%= actions %>
      </div>
    <% end %>
  </div>
</div>
