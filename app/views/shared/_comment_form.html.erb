<%= turbo_frame_tag "comment-form" do %>
  <% url = commentable.is_a?(Contact) ? contact_comments_path(commentable) : company_comments_path(commentable) %>
  <%= form_with url: url, class: "flex gap-2", data: { controller: "comment-form", action: "turbo:submit-end->comment-form#reset" } do |f| %>
    <%= f.text_area :body, placeholder: "Write a comment...", rows: 1,
      class: "form-input text-sm flex-1 resize-none py-2",
      data: { comment_form_target: "input" },
      required: true %>
    <button type="submit" class="btn-primary btn-sm self-end">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
    </button>
  <% end %>
<% end %>
