<nav class="fixed top-0 left-0 h-full w-56 bg-white border-r border-gray-200 flex flex-col z-10">
  <%# Logo %>
  <div class="px-4 py-4 border-b border-gray-100">
    <%= link_to root_path, class: "text-sm font-bold text-gray-900 hover:text-gray-700" do %>
      M2Leadflow
    <% end %>
  </div>

  <%# Primary nav %>
  <div class="flex-1 px-3 py-3 space-y-0.5 overflow-y-auto">
    <% nav_item = ->(label, path, ctrl) do %>
      <% active = controller_name == ctrl %>
      <%= link_to label, path, class: "flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium #{active ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:bg-gray-100'}" %>
    <% end %>

    <%= nav_item.call("Companies", companies_path, "companies") %>
    <%= nav_item.call("Meetings", meetings_path, "meetings") %>
    <%= nav_item.call("Settings", settings_path, "settings") %>

    <%# Contextual section — shown when inside a company or contact %>
    <% sidebar_company = defined?(@company) ? @company : (defined?(@contact) ? @contact&.company : nil) %>
    <% sidebar_contact = defined?(@contact) ? @contact : nil %>
    <% if sidebar_company.present? %>
      <div class="pt-4">
        <p class="px-3 mb-1 text-xs font-semibold text-gray-400 uppercase tracking-wide">Current Context</p>
        <%= link_to sidebar_company.name, sidebar_company, class: "flex items-center gap-2 px-3 py-1.5 rounded-md text-sm text-gray-700 hover:bg-gray-100 font-medium" %>
        <% if sidebar_contact.present? %>
          <%= link_to (sidebar_contact.name || sidebar_contact.email), sidebar_contact, class: "flex items-center gap-2 pl-6 pr-3 py-1.5 rounded-md text-sm text-gray-600 hover:bg-gray-100" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Bottom utilities %>
  <div class="px-3 py-3 border-t border-gray-100 space-y-0.5">
    <% active = controller_name == "task_monitor" %>
    <%= link_to "Task Monitor", task_monitor_index_path, class: "flex items-center gap-2.5 px-3 py-2 rounded-md text-sm font-medium #{active ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:bg-gray-100'}" %>
  </div>
</nav>
