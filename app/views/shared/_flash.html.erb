<% if notice.present? %>
  <div class="flex items-start gap-3 bg-white border border-emerald-200 shadow-lg rounded-xl px-4 py-3 min-w-[320px] max-w-md animate-slide-in-right"
       data-controller="toast" data-toast-delay-value="4000">
    <div class="flex-shrink-0 w-5 h-5 text-emerald-500 mt-0.5">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <p class="text-sm text-slate-700 flex-1"><%= notice %></p>
    <button type="button" data-action="toast#dismiss" class="text-slate-400 hover:text-slate-600 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
<% end %>
<% if alert.present? %>
  <div class="flex items-start gap-3 bg-white border border-rose-200 shadow-lg rounded-xl px-4 py-3 min-w-[320px] max-w-md animate-slide-in-right"
       data-controller="toast" data-toast-delay-value="4000">
    <div class="flex-shrink-0 w-5 h-5 text-rose-500 mt-0.5">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
    </div>
    <p class="text-sm text-slate-700 flex-1"><%= alert %></p>
    <button type="button" data-action="toast#dismiss" class="text-slate-400 hover:text-slate-600 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
<% end %>
