<%
  colors = {
    "new_company" => "bg-blue-100 text-blue-800",
    "processing" => "bg-yellow-100 text-yellow-800",
    "enriched" => "bg-green-100 text-green-800",
    "completed" => "bg-gray-100 text-gray-800",
    "pending" => "bg-yellow-100 text-yellow-800",
    "claimed" => "bg-blue-100 text-blue-800",
    "in_progress" => "bg-indigo-100 text-indigo-800",
    "failed" => "bg-red-100 text-red-800",
    "draft" => "bg-gray-100 text-gray-800",
    "approved" => "bg-blue-100 text-blue-800",
    "sent" => "bg-green-100 text-green-800",
    "active" => "bg-green-100 text-green-800",
    "exhausted" => "bg-red-100 text-red-800",
    "expired" => "bg-yellow-100 text-yellow-800",
    "revoked" => "bg-red-100 text-red-800",
    "scheduled" => "bg-blue-100 text-blue-800",
    "cancelled" => "bg-red-100 text-red-800",
    "skipped" => "bg-gray-100 text-gray-800",
    "pending_stage" => "bg-gray-100 text-gray-600",
    "drafted" => "bg-amber-100 text-amber-700",
    "replied" => "bg-emerald-100 text-emerald-700",
    "meeting" => "bg-violet-100 text-violet-700",
  }
  css = colors[status.to_s] || "bg-gray-100 text-gray-800"
%>
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= css %>">
  <%= status.to_s.humanize %>
</span>
