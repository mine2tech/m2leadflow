<%
  dot_colors = {
    "new_company" => "bg-amber-400",
    "processing" => "bg-amber-400",
    "enriched" => "bg-emerald-400",
    "completed" => "bg-emerald-400",
    "pending" => "bg-amber-400",
    "claimed" => "bg-sky-400",
    "in_progress" => "bg-sky-400",
    "failed" => "bg-rose-400",
    "draft" => "bg-slate-400",
    "approved" => "bg-sky-400",
    "sent" => "bg-emerald-400",
    "active" => "bg-emerald-400",
    "exhausted" => "bg-rose-400",
    "expired" => "bg-amber-400",
    "revoked" => "bg-rose-400",
    "scheduled" => "bg-sky-400",
    "cancelled" => "bg-rose-400",
    "skipped" => "bg-slate-400",
    "pending_stage" => "bg-slate-400",
    "drafted" => "bg-amber-400",
    "replied" => "bg-emerald-400",
    "meeting" => "bg-indigo-400",
  }
  variant = badge_variant_for(status)
  dot = dot_colors[status.to_s] || "bg-slate-400"
%>
<span class="badge <%= variant %>">
  <span class="w-1.5 h-1.5 rounded-full <%= dot %>"></span>
  <%= status.to_s.humanize %>
</span>
