<% return unless activity %>
<div class="flex gap-2.5">
  <div class="flex-shrink-0 mt-0.5">
    <% case activity.action %>
    <% when "email_sent" %>
      <div class="w-6 h-6 rounded-full bg-indigo-100 flex items-center justify-center">
        <svg class="w-3 h-3 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
      </div>
    <% when "reply_received" %>
      <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center">
        <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
      </div>
    <% when "comment_added" %>
      <div class="w-6 h-6 rounded-full bg-amber-100 flex items-center justify-center">
        <svg class="w-3 h-3 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      </div>
    <% when "draft_created", "draft_approved" %>
      <div class="w-6 h-6 rounded-full bg-sky-100 flex items-center justify-center">
        <svg class="w-3 h-3 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      </div>
    <% when "company_enriched" %>
      <div class="w-6 h-6 rounded-full bg-purple-100 flex items-center justify-center">
        <svg class="w-3 h-3 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
      </div>
    <% else %>
      <div class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center">
        <div class="w-2 h-2 rounded-full bg-slate-400"></div>
      </div>
    <% end %>
  </div>
  <div class="flex-1 min-w-0">
    <p class="text-sm text-slate-700">
      <% case activity.action %>
      <% when "email_sent" %>
        Email sent<% if activity.metadata["subject"].present? %>: <span class="font-medium"><%= activity.metadata["subject"].truncate(50) %></span><% end %>
      <% when "reply_received" %>
        <span class="font-medium text-emerald-700">Reply received</span>
      <% when "comment_added" %>
        <span class="font-medium"><%= activity.user&.name || "System" %></span> commented<% if activity.metadata["body"].present? %>: <span class="text-slate-500"><%= activity.metadata["body"].truncate(100) %></span><% end %>
      <% when "draft_created" %>
        Draft created
      <% when "draft_approved" %>
        Draft approved
      <% when "company_enriched" %>
        Company enriched
      <% when "contact_created" %>
        Contact added
      <% when "meeting_scheduled" %>
        Meeting scheduled
      <% when "followup_created" %>
        Followup created
      <% when "task_created" %>
        Task created
      <% else %>
        <%= activity.action.humanize %>
      <% end %>
    </p>
    <p class="text-xs text-slate-400 mt-0.5">
      <% if activity.user.present? %><%= activity.user.name %> &middot; <% end %>
      <%= time_ago_in_words(activity.created_at) %> ago
    </p>
  </div>
</div>
