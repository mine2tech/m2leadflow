<%= render "shared/page_header",
  breadcrumbs: [["Task Monitor", task_monitor_index_path], ["New Task", nil]],
  title: "Create Task" %>

<div class="card max-w-2xl">
  <div class="card-body">
    <% if @task.errors.any? %>
      <div class="mb-4 p-3 rounded-lg bg-red-50 border border-red-200">
        <ul class="text-sm text-red-600 list-disc list-inside">
          <% @task.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @task, url: task_monitor_index_path, class: "space-y-4", data: { controller: "task-form" } do |f| %>
      <div>
        <label class="form-label">Task Type</label>
        <%= f.select :task_type, Task::VALID_TYPES.map { |t| [t.humanize, t] },
          { prompt: "Select task type" },
          class: "form-input w-full",
          data: { task_form_target: "typeSelect", action: "task-form#updateTemplate" } %>
      </div>

      <div>
        <label class="form-label">Payload (JSON)</label>
        <textarea name="task[payload_json]" class="form-input font-mono text-sm w-full" rows="12"
          data-task-form-target="payload"
          required><%= params.dig(:task, :payload_json) || '{}' %></textarea>
        <p class="text-xs text-slate-400 mt-1">Enter a valid JSON object for the task payload.</p>
      </div>

      <%# Template hints %>
      <div data-task-form-target="hints" class="p-3 bg-slate-50 rounded-lg">
        <p class="text-xs font-medium text-slate-500 mb-2">Payload Templates</p>
        <details class="text-xs text-slate-600">
          <summary class="cursor-pointer hover:text-slate-800 font-medium">enrich_company</summary>
          <pre class="mt-1 bg-white p-2 rounded border text-xs overflow-x-auto">{
  "company_id": 1,
  "domain": "example.com"
}</pre>
        </details>
        <details class="text-xs text-slate-600 mt-2">
          <summary class="cursor-pointer hover:text-slate-800 font-medium">draft_email</summary>
          <pre class="mt-1 bg-white p-2 rounded border text-xs overflow-x-auto">{
  "contact_id": 1,
  "company_context": { "name": "Acme", "domain": "acme.com" },
  "contact": { "name": "John", "role": "CISO" },
  "is_followup": false,
  "sequence_number": 1
}</pre>
        </details>
        <details class="text-xs text-slate-600 mt-2">
          <summary class="cursor-pointer hover:text-slate-800 font-medium">company_research</summary>
          <pre class="mt-1 bg-white p-2 rounded border text-xs overflow-x-auto">{
  "criteria": {
    "industry": "fintech",
    "trend": "recently_breached",
    "count": 10,
    "employee_count_min": 500,
    "employee_count_max": 5000
  }
}</pre>
        </details>
      </div>

      <div class="flex gap-3 pt-4 border-t border-slate-100">
        <%= f.submit "Create Task", class: "btn-primary cursor-pointer" %>
        <%= link_to "Cancel", task_monitor_index_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
