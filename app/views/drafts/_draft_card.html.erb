<%= turbo_frame_tag dom_id(draft) do %>
  <div class="rounded-xl border p-4 transition-all duration-200 <%= draft.sent? ? 'bg-slate-50 border-slate-200' : 'bg-amber-50/50 border-amber-200 border-dashed' %>">
    <div class="flex items-start justify-between mb-2">
      <% if draft.sent? %>
        <span class="badge badge-success">Sent</span>
      <% elsif draft.approved? %>
        <span class="badge badge-info">Approved — ready to send</span>
      <% else %>
        <span class="badge badge-warning">Draft — pending review</span>
      <% end %>
      <span class="text-xs text-slate-400"><%= draft.created_at.strftime("%b %-d") %></span>
    </div>

    <% if draft.subject.present? %>
      <p class="text-sm font-medium text-slate-800 mb-1"><%= draft.subject %></p>
    <% end %>
    <p class="text-sm text-slate-600 whitespace-pre-wrap line-clamp-6"><%= draft.body %></p>

    <% unless draft.sent? %>
      <div class="flex items-center gap-2 mt-3">
        <%= link_to "Edit", edit_draft_path(draft), class: "btn-ghost btn-sm text-xs" %>
        <% if draft.draft? %>
          <%= button_to "Approve", approve_draft_path(draft), method: :post, class: "btn-primary btn-sm text-xs" %>
        <% end %>
        <% if draft.approved? %>
          <%= button_to "Send Email", send_email_draft_path(draft), method: :post,
            class: "btn-primary btn-sm text-xs",
            data: { turbo_confirm: "Send this email?" } %>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
