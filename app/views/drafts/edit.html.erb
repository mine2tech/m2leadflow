<%= render "shared/page_header",
  breadcrumbs: [["Drafts", drafts_path], [@draft.contact.name || @draft.contact.email, contact_path(@draft.contact)], ["Edit Draft", nil]],
  title: "Edit Draft" %>

<div class="card max-w-3xl">
  <div class="card-header">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center flex-shrink-0">
        <span class="text-xs font-bold text-slate-600"><%= initials_for(@draft.contact.name) %></span>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-900">
          To: <%= @draft.contact.name || "" %> &lt;<%= @draft.contact.email %>&gt;
        </p>
        <p class="text-xs text-slate-500"><%= @draft.contact.company.name %></p>
      </div>
    </div>
  </div>
  <div class="card-body">
    <%= form_with(model: @draft, class: "space-y-4") do |f| %>
      <div>
        <label class="form-label">Subject</label>
        <%= f.text_field :subject, class: "form-input" %>
      </div>

      <div>
        <label class="form-label">Body</label>
        <%= f.text_area :body, class: "form-input font-mono", rows: 15 %>
      </div>

      <div>
        <label class="form-label">Attachments</label>
        <% if @draft.attachments.any? %>
          <div class="flex flex-wrap gap-2 mb-2">
            <% @draft.attachments.each do |attachment| %>
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-100 rounded-lg text-sm text-slate-700">
                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
                <%= attachment.filename %>
                <span class="text-xs text-slate-400">(<%= number_to_human_size(attachment.byte_size) %>)</span>
              </span>
            <% end %>
          </div>
        <% end %>
        <%= f.file_field :attachments, multiple: true, class: "form-input text-sm file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
        <p class="text-xs text-slate-400 mt-1">Add PDFs, PPTs, or other files. New uploads are added to existing attachments.</p>
      </div>

      <div class="flex gap-3 pt-4 border-t border-slate-100">
        <%= f.submit "Save Draft", class: "btn-primary cursor-pointer" %>
        <%= link_to "Cancel", contact_path(@draft.contact), class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
