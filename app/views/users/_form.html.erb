<%= form_with(model: user, class: "space-y-6") do |f| %>
  <% if user.errors.any? %>
    <div class="p-3 rounded-lg bg-red-50 border border-red-200">
      <ul class="text-sm text-red-600 list-disc list-inside">
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-input w-full", required: true %>
    </div>

    <div>
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, class: "form-input w-full", required: true %>
    </div>

    <div>
      <%= f.label :role, class: "form-label" %>
      <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, class: "form-input w-full" %>
    </div>

    <div>
      <%= f.label :password, user.persisted? ? "New Password (leave blank to keep)" : "Password", class: "form-label" %>
      <%= f.password_field :password, class: "form-input w-full", required: user.new_record?, autocomplete: "new-password" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
      <%= f.password_field :password_confirmation, class: "form-input w-full", required: user.new_record?, autocomplete: "new-password" %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-4 border-t border-slate-200">
    <%= f.submit user.persisted? ? "Update User" : "Create User", class: "btn-primary" %>
    <%= link_to "Cancel", users_path, class: "btn-ghost" %>
  </div>
<% end %>
