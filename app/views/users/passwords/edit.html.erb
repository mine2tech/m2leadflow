<h2 class="text-lg font-semibold text-slate-900 mb-6">Change your password</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
  <%= render "users/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div>
    <%= f.label :password, "New password", class: "form-label" %>
    <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-input w-full" %>
    <p class="text-xs text-slate-500 mt-1"><%= @minimum_password_length %> characters minimum</p>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input w-full" %>
  </div>

  <div>
    <%= f.submit "Change my password", class: "btn-primary w-full justify-center" %>
  </div>
<% end %>

<p class="text-center text-sm text-slate-500 mt-4">
  <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-700" %>
</p>
