<h2 class="text-lg font-semibold text-slate-900 mb-6">Forgot your password?</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
  <%= render "users/shared/error_messages", resource: resource %>

  <div>
    <%= f.label :email, class: "form-label" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input w-full", placeholder: "you@example.com" %>
  </div>

  <div>
    <%= f.submit "Send reset instructions", class: "btn-primary w-full justify-center" %>
  </div>
<% end %>

<p class="text-center text-sm text-slate-500 mt-4">
  <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-700" %>
</p>
