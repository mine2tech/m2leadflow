<%= render "shared/page_header", title: "Users", subtitle: "Manage user accounts and roles" do %>
  <%= link_to new_user_path, class: "btn-primary" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Add User
  <% end %>
<% end %>

<div class="card">
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Last Sign In</th>
        <th class="text-right">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td class="font-medium text-slate-900">
            <%= user.name %>
            <% if user == current_user %>
              <span class="text-xs text-slate-400 ml-1">(you)</span>
            <% end %>
          </td>
          <td class="text-slate-600"><%= user.email %></td>
          <td>
            <span class="badge badge-<%= user.admin? ? 'primary' : user.editor? ? 'info' : 'neutral' %>">
              <%= user.role.humanize %>
            </span>
          </td>
          <td class="text-slate-500 text-sm">
            <% if user.last_sign_in_at %>
              <%= time_ago_in_words(user.last_sign_in_at) %> ago
            <% else %>
              Never
            <% end %>
          </td>
          <td class="text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to "Edit", edit_user_path(user), class: "btn-ghost btn-sm" %>
              <% unless user == current_user %>
                <%= button_to "Delete", user_path(user), method: :delete,
                  class: "btn-danger btn-sm",
                  data: { turbo_confirm: "Are you sure you want to delete #{user.name}?" } %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
