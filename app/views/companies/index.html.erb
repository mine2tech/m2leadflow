<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Companies</h1>
  <%= link_to "Add Company", new_company_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Domain</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Contacts</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @companies.each do |company| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4">
            <%= link_to company.name, company, class: "text-blue-600 hover:text-blue-800 font-medium" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= company.domain %></td>
          <td class="px-6 py-4"><%= render "shared/status_badge", status: company.status %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= company.contacts.count %></td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= company.created_at.strftime("%b %d, %Y") %></td>
          <td class="px-6 py-4 text-right">
            <%= link_to "Edit", edit_company_path(company), class: "text-sm text-gray-600 hover:text-gray-900" %>
          </td>
        </tr>
      <% end %>
      <% if @companies.empty? %>
        <tr>
          <td colspan="6" class="px-6 py-8 text-center text-gray-500">No companies yet. Add your first target company.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
