<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-xl font-semibold text-gray-900"><%= @company.name %></h1>
    <p class="text-xs text-gray-500 mt-1"><%= @company.domain %> &middot; <%= render "shared/status_badge", status: @company.status %></p>
  </div>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_company_path(@company), class: "px-3 py-2 text-sm border border-gray-300 rounded-md text-gray-600 hover:text-gray-900" %>
    <%= link_to "Add Contact", new_company_contact_path(@company), class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700" %>
  </div>
</div>

<% if @company.notes.present? %>
  <div class="bg-white rounded-lg border border-gray-200 p-4 mb-6">
    <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Notes</h3>
    <p class="text-sm text-gray-700"><%= simple_format(@company.notes) %></p>
  </div>
<% end %>

<%# Stage filter bar %>
<% all_contacts = @company.contacts %>
<% stage_counts = all_contacts.group_by(&:pipeline_stage).transform_values(&:count) %>
<% stages = [:pending, :drafted, :sent, :replied, :meeting] %>
<div class="flex items-center gap-2 mb-4 flex-wrap">
  <%= link_to "All (#{all_contacts.count})", company_path(@company),
    class: "px-3 py-1 text-sm rounded-full #{params[:stage].blank? ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100 border border-gray-200'}" %>
  <% stages.each do |stage| %>
    <% count = stage_counts[stage] || 0 %>
    <%= link_to "#{stage.to_s.capitalize} (#{count})", company_path(@company, stage: stage),
      class: "px-3 py-1 text-sm rounded-full #{params[:stage] == stage.to_s ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100 border border-gray-200'}" %>
  <% end %>
</div>

<h2 class="text-sm font-semibold text-gray-900 mb-3">Contacts (<%= @contacts.count %>)</h2>

<% stage_colors = {
  pending: "bg-gray-100 text-gray-600",
  drafted: "bg-amber-100 text-amber-700",
  sent:    "bg-blue-100 text-blue-700",
  replied: "bg-emerald-100 text-emerald-700",
  meeting: "bg-violet-100 text-violet-700"
} %>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Stage</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Activity</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @contacts.each do |contact| %>
        <% stage = contact.pipeline_stage %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4">
            <%= link_to contact.name || "—", contact, class: "text-blue-600 hover:text-blue-800 text-sm font-medium" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= contact.email %></td>
          <td class="px-6 py-4 text-sm text-gray-600"><%= contact.role || "—" %></td>
          <td class="px-6 py-4">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= stage_colors[stage] %>">
              <%= stage.to_s.capitalize %>
            </span>
          </td>
          <td class="px-6 py-4 text-xs text-gray-500">
            <% last_at = contact.last_outbound_at || contact.updated_at %>
            <%= last_at.strftime("%b %d") %>
          </td>
        </tr>
      <% end %>
      <% if @contacts.empty? %>
        <tr>
          <td colspan="5" class="px-6 py-8 text-center text-sm text-gray-500">No contacts yet.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
