<%= form_with(model: company, class: "space-y-4") do |f| %>
  <% if company.errors.any? %>
    <div class="bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-lg text-sm">
      <ul class="list-disc list-inside">
        <% company.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <label class="form-label">Name</label>
    <%= f.text_field :name, class: "form-input", required: true %>
  </div>

  <div>
    <label class="form-label">Domain</label>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
      </div>
      <%= f.text_field :domain, class: "form-input pl-9", placeholder: "example.com", required: true %>
    </div>
    <p class="text-xs text-slate-400 mt-1">The company's website domain, without https://</p>
  </div>

  <div>
    <label class="form-label">Notes</label>
    <%= f.text_area :notes, class: "form-input", rows: 3 %>
    <p class="text-xs text-slate-400 mt-1">Optional notes about this company or your outreach strategy.</p>
  </div>

  <% if company.persisted? %>
    <details class="pt-2 border-t border-slate-100">
      <summary class="text-sm font-medium text-slate-700 cursor-pointer hover:text-slate-900 py-2">Company Intelligence Fields</summary>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-3">
        <div>
          <label class="form-label">Industry</label>
          <%= f.text_field :industry, class: "form-input" %>
        </div>
        <div>
          <label class="form-label">Employee Count</label>
          <%= f.number_field :employee_count, class: "form-input" %>
        </div>
        <div>
          <label class="form-label">Revenue Range</label>
          <%= f.text_field :revenue_range, class: "form-input", placeholder: "$10M-$50M" %>
        </div>
        <div>
          <label class="form-label">Headquarters</label>
          <%= f.text_field :headquarters, class: "form-input" %>
        </div>
        <div>
          <label class="form-label">Funding Info</label>
          <%= f.text_field :funding_info, class: "form-input" %>
        </div>
        <div>
          <label class="form-label">Security Posture</label>
          <%= f.text_field :security_posture, class: "form-input" %>
        </div>
        <div class="md:col-span-2">
          <label class="form-label">Tech Stack</label>
          <%= f.text_area :tech_stack, class: "form-input", rows: 2 %>
        </div>
        <div class="md:col-span-2">
          <label class="form-label">Recent Breaches</label>
          <%= f.text_area :recent_breaches, class: "form-input", rows: 2 %>
        </div>
        <div class="md:col-span-2">
          <label class="form-label">Website Description</label>
          <%= f.text_area :website_description, class: "form-input", rows: 2 %>
        </div>
      </div>
    </details>
  <% end %>

  <div class="flex gap-3 pt-2 border-t border-slate-100">
    <%= f.submit class: "btn-primary cursor-pointer" %>
    <%= link_to "Cancel", company.persisted? ? company_path(company) : companies_path, class: "btn-secondary" %>
  </div>
<% end %>
