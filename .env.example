# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

# HTTP Basic Auth for UI
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=

# API Key for external Claude agent
API_KEY=

# SMTP (Google Workspace)
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_DOMAIN=
SMTP_USERNAME=
SMTP_PASSWORD=

# Gmail OAuth (for reply tracking)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/auth/gmail/callback

# Google Calendar OAuth (separate account for meeting scheduling)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/auth/calendar/callback

# Followup defaults
DEFAULT_FOLLOWUP_DELAY_DAYS=3
DEFAULT_MAX_FOLLOWUPS=3
